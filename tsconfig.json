{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "~/*": ["./app/*"]
    },
    "baseUrl": "."
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "api/**/*.ts", "prisma/**/*.ts"],
  "exclude": ["node_modules", "build", "admin"]
}
