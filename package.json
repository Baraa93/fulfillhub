{
  "name": "fulfillhub",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Shopify dropshipping/fulfillment platform — Turkey to GCC",
  "scripts": {
    "dev": "shopify app dev",
    "build": "remix vite:build",
    "start": "node server.js",
    "start:remix": "remix-serve ./build/server/index.js",
    "dev:admin-api": "tsx watch api/index.ts",
    "dev:admin-ui": "cd admin && npm run dev",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@remix-run/express": "^2.17.4",
    "@remix-run/node": "^2.17.0",
    "@remix-run/react": "^2.17.0",
    "@remix-run/serve": "^2.17.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^13.0.0",
    "@shopify/shopify-api": "^12.3.0",
    "@shopify/shopify-app-remix": "^4.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "isbot": "^5.1.35",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "prisma": "^6.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
