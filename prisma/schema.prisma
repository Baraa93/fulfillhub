generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// SHOPIFY SESSION (required by @shopify/shopify-app-remix)
// ─────────────────────────────────────────────

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// ─────────────────────────────────────────────
// SELLER (Shopify Store)
// ─────────────────────────────────────────────

model Seller {
  id                String    @id @default(cuid())
  shopDomain        String    @unique                 // e.g. "mystore.myshopify.com"
  shopName          String?
  email             String?
  accessToken       String                            // Shopify access token (encrypted in prod)
  status            SellerStatus @default(ACTIVE)
  currency          String    @default("USD")
  walletBalance     Decimal   @default(0) @db.Decimal(12, 2)
  packagingInsert   String?                           // insert card text
  brandedPackaging  Boolean   @default(false)
  packagingNotes    String?
  installedAt       DateTime  @default(now())
  uninstalledAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders            Order[]
  sellerProducts    SellerProduct[]
  productRequests   ProductRequest[]
  walletTransactions WalletTransaction[]
  auditLogs         AuditLog[]

  @@index([shopDomain])
}

enum SellerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ─────────────────────────────────────────────
// CATALOG PRODUCT (internal, curated)
// ─────────────────────────────────────────────

model CatalogProduct {
  id                  String    @id @default(cuid())
  sku                 String    @unique               // e.g. "FH-TWL-001"
  title               String
  description         String?   @db.Text
  bodyHtml            String?   @db.Text
  category            String?
  tags                String[]
  images              String[]                        // array of image URLs
  vendor              String?
  productType         String?
  status              CatalogProductStatus @default(ACTIVE)

  // Sourcing
  sourceUrl           String?                         // internal reference (e.g., Trendyol link)
  supplierName        String?
  supplierCost        Decimal   @db.Decimal(10, 2)    // our cost from supplier
  costCurrency        String    @default("TRY")

  // Shipping & Eligibility
  weightKg            Decimal?  @db.Decimal(6, 3)
  lengthCm            Decimal?  @db.Decimal(6, 1)
  widthCm             Decimal?  @db.Decimal(6, 1)
  heightCm            Decimal?  @db.Decimal(6, 1)
  eligibleCountries   String[]  @default(["AE", "SA", "KW", "QA", "OM", "BH"])
  customsRiskFlag     CustomsRisk @default(LOW)
  restrictedCategory  Boolean   @default(false)

  // Stock
  stockType           StockType @default(ON_DEMAND)
  stockQuantity       Int       @default(0)           // relevant for IN_WAREHOUSE
  leadTimeDays        Int       @default(5)           // for ON_DEMAND

  // Pricing rules
  suggestedPriceUsd   Decimal   @db.Decimal(10, 2)
  minSellerPriceUsd   Decimal?  @db.Decimal(10, 2)    // floor price

  // Scoring
  demandScore         Int?      @db.SmallInt          // 1-5
  marginScore         Int?      @db.SmallInt
  shippingScore       Int?      @db.SmallInt
  customsScore        Int?      @db.SmallInt
  returnScore         Int?      @db.SmallInt
  overallScore        Decimal?  @db.Decimal(3, 2)     // weighted average

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  variants            CatalogVariant[]
  sellerProducts      SellerProduct[]
  orderLineItems      OrderLineItem[]

  @@index([status])
  @@index([category])
  @@index([sku])
}

enum CatalogProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum CustomsRisk {
  LOW
  MEDIUM
  HIGH
}

enum StockType {
  IN_WAREHOUSE
  ON_DEMAND
}

model CatalogVariant {
  id                String    @id @default(cuid())
  catalogProductId  String
  catalogProduct    CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)
  sku               String    @unique               // e.g. "FH-TWL-001-WH-L"
  title             String                           // e.g. "White / Large"
  option1           String?                          // e.g. "White"
  option2           String?                          // e.g. "Large"
  option3           String?
  priceUsd          Decimal   @db.Decimal(10, 2)
  costTry           Decimal?  @db.Decimal(10, 2)
  weightKg          Decimal?  @db.Decimal(6, 3)
  barcode           String?
  stockQuantity     Int       @default(0)
  status            CatalogProductStatus @default(ACTIVE)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sellerProducts    SellerProduct[]
  orderLineItems    OrderLineItem[]

  @@index([catalogProductId])
}

// ─────────────────────────────────────────────
// SELLER PRODUCT (imported into Shopify store)
// ─────────────────────────────────────────────

model SellerProduct {
  id                  String    @id @default(cuid())
  sellerId            String
  seller              Seller    @relation(fields: [sellerId], references: [id])
  catalogProductId    String
  catalogProduct      CatalogProduct @relation(fields: [catalogProductId], references: [id])
  catalogVariantId    String?
  catalogVariant      CatalogVariant? @relation(fields: [catalogVariantId], references: [id])

  shopifyProductId    String?                         // Shopify product GID or numeric ID
  shopifyVariantId    String?                         // Shopify variant GID
  sellerPrice         Decimal   @db.Decimal(10, 2)    // price set by seller
  status              SellerProductStatus @default(ACTIVE)
  importedAt          DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([sellerId, catalogVariantId])
  @@index([sellerId])
  @@index([shopifyVariantId])
  @@index([shopifyProductId])
}

enum SellerProductStatus {
  ACTIVE
  PAUSED
  DELETED
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id                  String    @id @default(cuid())
  sellerId            String
  seller              Seller    @relation(fields: [sellerId], references: [id])

  // Shopify references
  shopifyOrderId      String                          // Shopify order GID or numeric ID
  shopifyOrderNumber  String?                         // Human-readable order number (#1001)
  shopifyOrderName    String?                         // "#1001"

  status              OrderStatus @default(PROCESSING)
  statusNote          String?                         // e.g. "OOS: variant FH-TWL-001-WH-L"

  // Customer shipping address (denormalized for ops)
  customerName        String?
  customerEmail       String?
  shippingAddress1    String?
  shippingAddress2    String?
  shippingCity        String?
  shippingProvince    String?
  shippingCountry     String?                         // ISO 2-letter
  shippingZip         String?
  shippingPhone       String?

  // Financial
  totalAmountUsd      Decimal   @db.Decimal(10, 2)    // amount charged to seller wallet
  walletDeducted      Boolean   @default(false)

  // Carrier
  assignedCarrier     Carrier?
  carrierOverride     Boolean   @default(false)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  paidAt              DateTime?                       // from Shopify
  packedAt            DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?

  lineItems           OrderLineItem[]
  shipments           Shipment[]
  auditLogs           AuditLog[]

  @@unique([sellerId, shopifyOrderId])
  @@index([sellerId])
  @@index([status])
  @@index([shopifyOrderId])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING_PAYMENT       // wallet insufficient
  PROCESSING            // received, being handled
  PURCHASED             // stock purchased/allocated from supplier
  ALLOCATED             // stock confirmed in warehouse
  PACKED                // ready to ship
  SHIPPED               // carrier has it
  DELIVERED
  EXCEPTION             // OOS, address error, customs hold, etc.
  CANCELLED
  RETURNED
}

enum Carrier {
  ARAMEX
  SMSA
}

model OrderLineItem {
  id                  String    @id @default(cuid())
  orderId             String
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  catalogProductId    String?
  catalogProduct      CatalogProduct? @relation(fields: [catalogProductId], references: [id])
  catalogVariantId    String?
  catalogVariant      CatalogVariant? @relation(fields: [catalogVariantId], references: [id])

  shopifyLineItemId   String                          // Shopify line item ID
  shopifyVariantId    String?                         // Shopify variant ID (for mapping)

  title               String
  variantTitle        String?
  sku                 String?                         // our internal SKU
  quantity            Int
  priceUsd            Decimal   @db.Decimal(10, 2)    // seller price per unit
  costUsd             Decimal?  @db.Decimal(10, 2)    // our cost per unit

  status              LineItemStatus @default(PENDING)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orderId])
}

enum LineItemStatus {
  PENDING
  ALLOCATED
  PACKED
  SHIPPED
  EXCEPTION
  CANCELLED
}

// ─────────────────────────────────────────────
// SHIPMENT
// ─────────────────────────────────────────────

model Shipment {
  id                  String    @id @default(cuid())
  orderId             String
  order               Order     @relation(fields: [orderId], references: [id])

  carrier             Carrier
  trackingNumber      String?
  trackingUrl         String?
  labelUrl            String?                         // URL to label PDF

  status              ShipmentStatus @default(PENDING)
  carrierStatus       String?                         // raw status from carrier
  createdVia          ShipmentCreatedVia @default(API)

  // Shopify fulfillment reference
  shopifyFulfillmentId String?
  trackingPushed       Boolean  @default(false)

  // Parcel info
  weightKg            Decimal?  @db.Decimal(6, 3)
  packageCount        Int       @default(1)

  estimatedDelivery   DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?

  carrierRawResponse  Json?                           // full API response for debugging

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([orderId])
  @@index([trackingNumber])
  @@index([status])
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  RETURNED
}

enum ShipmentCreatedVia {
  API
  MANUAL
}

// ─────────────────────────────────────────────
// PRODUCT REQUEST (seller → admin)
// ─────────────────────────────────────────────

model ProductRequest {
  id                String    @id @default(cuid())
  sellerId          String
  seller            Seller    @relation(fields: [sellerId], references: [id])

  trendyolUrl       String
  notes             String?   @db.Text
  desiredCategory   String?
  status            ProductRequestStatus @default(PENDING)
  adminNotes        String?   @db.Text
  reviewedBy        String?                           // admin user ID
  reviewedAt        DateTime?

  // If approved, link to created catalog product
  catalogProductId  String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([sellerId])
  @@index([status])
}

enum ProductRequestStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// WALLET / BILLING
// ─────────────────────────────────────────────

model WalletTransaction {
  id              String    @id @default(cuid())
  sellerId        String
  seller          Seller    @relation(fields: [sellerId], references: [id])

  type            WalletTransactionType
  amount          Decimal   @db.Decimal(12, 2)        // positive for credit, negative for debit
  balanceAfter    Decimal   @db.Decimal(12, 2)
  description     String
  referenceType   String?                             // "order", "topup", "adjustment", "refund"
  referenceId     String?                             // order ID or topup ID

  createdBy       String?                             // admin user ID if manual
  createdAt       DateTime  @default(now())

  @@index([sellerId])
  @@index([createdAt])
}

enum WalletTransactionType {
  CREDIT        // top-up, refund
  DEBIT         // order charge
  ADJUSTMENT    // manual admin adjustment
}

// ─────────────────────────────────────────────
// ADMIN USER
// ─────────────────────────────────────────────

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          AdminRole @default(ADMIN)
  status        AdminUserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  WAREHOUSE
}

enum AdminUserStatus {
  ACTIVE
  INACTIVE
}

// ─────────────────────────────────────────────
// WEBHOOK LOG (idempotency)
// ─────────────────────────────────────────────

model WebhookLog {
  id                String    @id @default(cuid())
  shopifyWebhookId  String    @unique                 // X-Shopify-Webhook-Id header
  topic             String                            // e.g. "orders/paid"
  shopDomain        String
  processedAt       DateTime  @default(now())
  payload           Json?                             // store for debugging (truncated in prod)
  status            WebhookLogStatus @default(PROCESSED)
  errorMessage      String?

  @@index([shopifyWebhookId])
  @@index([processedAt])
}

enum WebhookLogStatus {
  PROCESSED
  FAILED
  SKIPPED
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id            String    @id @default(cuid())
  actorType     ActorType                             // ADMIN, SELLER, SYSTEM
  actorId       String?                               // admin user ID or seller ID
  action        String                                // e.g. "order.status_changed"
  entityType    String                                // e.g. "Order", "CatalogProduct"
  entityId      String
  details       Json?                                 // { from: "PROCESSING", to: "PACKED" }
  sellerId      String?                               // for tenant scoping
  seller        Seller?   @relation(fields: [sellerId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id])
  createdAt     DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([sellerId])
  @@index([createdAt])
}

enum ActorType {
  ADMIN
  SELLER
  SYSTEM
}

// ─────────────────────────────────────────────
// SHIPPING RULES
// ─────────────────────────────────────────────

model ShippingRule {
  id              String    @id @default(cuid())
  country         String                              // ISO 2-letter code
  defaultCarrier  Carrier
  maxWeightKg     Decimal?  @db.Decimal(6, 3)
  baseCostUsd     Decimal?  @db.Decimal(10, 2)
  perKgCostUsd    Decimal?  @db.Decimal(10, 2)
  estimatedDays   Int?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([country])
}
